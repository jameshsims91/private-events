<h1><%= @user.name %>'s Profile</h1>
<p>Email: <%= @user.email %></p>

<h2>Events Created</h2>
<% if @created_events.any? %>
  <ul>
    <% @created_events.each do | event | %>
      <li>
        <%= link_to event.title, event_path(event) %>
        - <%= event.date.strftime("%B %d, %y") if event.date %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>This user hasn't created any events yet.</p>
<% end %>

<hr>

<nav class="profile-naviagation">
  <%= link_to "🏠 Back to All Events", root_path %> |
  <% if @user == current_user %>
    <%= link_to "➕ Create New Event", new_event_path %>
  <% end %>
</nav>

