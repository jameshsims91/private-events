<h1><%= @user.name %>'s Profile</h1>
<p>Email: <%= @user.email %></p>

<section class="profile-section">
  <h2>🛠️ Events Created by <%= @user.name %></h2>
  <% if @created_events.any? %>
    <ul>
      <% @created_events.each do | event | %>
        <li>
          <%= link_to event.title, event_path(event) %>
          - <%= event.date.strftime("%B %d, %Y") if event.date %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p>This user hasn't created any events yet.</p>
  <% end %>
</section>

<hr>

<section class= "profile-section">
  <h2>📅 Upcoming Events Attending</h2>
  <% if @upcoming_attended_events.any? %>
    <ul>
      <% @upcoming_attended_events.each do | event | %>
        <li>
          <%= link_to event.title, event_path(event) %>
          (Hosted by: <%= event.creator.name %> on <%= event.date.strftime("%B %d, %Y") %>)
        </li>
      <% end %>
    </ul>
  <% else %>
    <p>Not RSVP'd to any upcoming events.</p>
  <% end %>
</section>

<hr>
 
<section class="profile-section">
  <h2>⏳ Past Events Attended</h2>
  <% if @past_attended_events.any? %>
    <ul>
      <% @past_attended_events.each do | event | %>
        <li>
          <%= link_to event.title, event_path(event) %>
          (Hosted by: <%= event.creator.name %> on <%= event.date.strftime("%B %d, %Y") %>)
        </li>
      <% end %>
    </ul>
  <% else %>
    <p>No past events attended.</p>
  <% end %>
</section>

<hr>
<nav class="profile-naviagation">
  <%= link_to "🏠 Back to All Events", root_path %> |
  <% if @user == current_user %>
    <%= link_to "➕ Create New Event", new_event_path %>
  <% end %>
</nav>

