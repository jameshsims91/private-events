<h1>Edit Event</h1>

<%= form_with model: @event do | f | %>
  <% if @event.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@event.errors.count, "error") %> prohibited this event from being saved:</h2>
      <ul>
        <% @event.errors.full_messages.each do | msg | %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :title %>
    <%= f.text_field :title, required: true %>
  </div>

  <div class="field">
    <%= f.label :date %>
    <%= f.date_field :date, required: true %>
  </div>

  <div class="field">
    <%= f.label :description %>
    <%= f.text_area :description, rows: 5 %>
  </div>

  <div class="field">
    <%= f.label :private, "Make this event private (invite-only)" %>
    <%= f.check_box :private %>
  </div>

  <div class="actions">
    <%= f.submit "Update Event" %>
  </div>
<% end %>

<hr>

<%= link_to "Cancel and Back", event_path(@event) %>